# --- Family Budget environment variables ---

# Postgres connection string (Neon).
# On Vercel + Neon integration this is provided automatically as DATABASE_URL.
# Neon requires SSL; postgres.js is configured to enable it for non-local hosts.
DATABASE_URL="postgres://user:password@host/dbname?sslmode=require"

# The single shared household password both partners type on the login screen.
APP_PASSWORD="change-me-to-a-shared-passphrase"

# Secret used to sign the session cookie. Use a long random string.
# Generate one with:  openssl rand -base64 32
SESSION_SECRET="change-me-to-a-long-random-secret"
