# --- Family Budget: self-hosted (Docker Compose) ---
# Copy this file to ".env" next to docker-compose.yml and fill it in.
#   cp .env.docker.example .env

# Your domain (DNS A/AAAA record must point at this VPS). Caddy gets HTTPS
# automatically for it. Example: budget.yourdomain.com
DOMAIN=budget.example.com

# Email for Let's Encrypt (renewal/expiry notices). Optional but recommended.
TLS_EMAIL=you@example.com

# The single shared household password both partners type to log in.
APP_PASSWORD=change-me-to-a-shared-passphrase

# Secret used to sign the session cookie. Generate one with:
#   openssl rand -base64 32
SESSION_SECRET=change-me-to-a-long-random-secret

# Postgres credentials (the database runs in the stack).
POSTGRES_USER=budget
POSTGRES_PASSWORD=change-me-to-a-strong-db-password
POSTGRES_DB=family_budget
